# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://virtue:virtuepass@postgres:5432/virtue

# ─── Qdrant Vector DB ────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── Ollama LLM ──────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434/api/generate

# ─── Service-to-Service Auth (REQUIRED - change in production) ──
SERVICE_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_MIN_32_CHARS

# ─── JWT Auth (REQUIRED - change in production) ──────────────
JWT_SECRET_KEY=CHANGE_THIS_JWT_SECRET_IN_PRODUCTION_MIN_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Demo Mode (set true to skip Ollama for live demo) ───────
# When DEMO_MODE=true, the API returns mock advisory responses
# so the live demo works without a running Ollama instance.
DEMO_MODE=false
